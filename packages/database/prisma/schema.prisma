generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id             String          @id @default(cuid())
    email          String          @unique
    emailVerified  DateTime?
    name           String?
    bio            String?
    timezone       String?         @default("UTC")
    totalFocusTime Int             @default(0)
    currentStreak  Int             @default(0)
    longestStreak  Int             @default(0)
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt
    password       String?
    image          String?
    accounts       Account[]
    aiInteractions AIInteraction[]
    dailyStats     DailyStats[]
    focusSessions  FocusSession[]
    posts          Post[]
    sessions       Session[]
    tasks          Task[]
    userBadges     UserBadge[]

    @@index([email])
    @@map("users")
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?
    user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
    @@map("accounts")
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("sessions")
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
    @@map("verification_tokens")
}

model Task {
    id                    String                 @id @default(cuid())
    title                 String
    description           String?
    status                TaskStatus             @default(BACKLOG)
    priority              TaskPriority           @default(MEDIUM)
    completedPomodoros    Int                    @default(0)
    focusTotalSessions    Int? // Total sessions planned for current focus cycle
    order                 Int                    @default(0)
    tags                  String[]
    dueDate               DateTime?
    completedAt           DateTime?
    estimatedPomodoros    Int?
    suggestedSessionType  String? // "QUICK_5" | "QUICK_15" | "STANDARD" — AI suggested focus mode
    suggestedSessions     Int? // Number of sessions AI suggested
    suggestedTotalMinutes Int? // Total estimated minutes from AI
    embedding             Unsupported("vector")?
    isArchived            Boolean                @default(false)
    userId                String
    createdAt             DateTime               @default(now())
    updatedAt             DateTime               @updatedAt
    focusSessions         FocusSession[]
    posts                 Post[]
    user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, status])
    @@index([userId, isArchived])
    @@index([status])
    @@index([userId, status, order])
    @@map("tasks")
}

model Post {
    id        String      @id @default(cuid())
    content   String
    isPublic  Boolean     @default(true)
    viewCount Int         @default(0)
    likeCount Int         @default(0)
    taskId    String?
    userId    String
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt
    images    PostImage[]
    task      Task?       @relation(fields: [taskId], references: [id])
    user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([createdAt])
    @@index([isPublic, createdAt])
    @@map("posts")
}

model PostImage {
    id        String   @id @default(cuid())
    url       String
    width     Int?
    height    Int?
    size      Int?
    format    String?
    postId    String
    createdAt DateTime @default(now())
    post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

    @@index([postId])
    @@map("post_images")
}

model FocusSession {
    id              String             @id @default(cuid())
    startedAt       DateTime
    endedAt         DateTime?
    duration        Int?
    plannedDuration Int                @default(1500)
    elapsedTime     Int                @default(0) // seconds elapsed when paused
    status          FocusSessionStatus @default(IN_PROGRESS)
    taskId          String?
    userId          String
    breakDuration   Int?
    createdAt       DateTime           @default(now())
    updatedAt       DateTime           @updatedAt
    task            Task?              @relation(fields: [taskId], references: [id])
    user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, startedAt])
    @@index([userId, status])
    @@index([startedAt])
    @@map("focus_sessions")
}

model DailyStats {
    id                 String   @id @default(cuid())
    date               DateTime @db.Date
    totalFocusTime     Int      @default(0)
    completedPomodoros Int      @default(0)
    completedTasks     Int      @default(0)
    userId             String
    createdAt          DateTime @default(now())
    updatedAt          DateTime @updatedAt
    user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, date])
    @@index([date])
    @@index([date, totalFocusTime])
    @@map("daily_stats")
}

model AIInteraction {
    id         String            @id @default(cuid())
    type       AIInteractionType
    userPrompt String?
    context    Json?
    aiResponse String
    wasHelpful Boolean?
    model      String            @default("gemini-2.5-flash")
    tokensUsed Int?
    userId     String
    createdAt  DateTime          @default(now())
    user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, createdAt])
    @@index([type])
    @@map("ai_interactions")
}

model Badge {
    id          String        @id @default(cuid())
    name        String        @unique
    description String
    icon        String
    category    BadgeCategory
    criteria    Json
    rarity      String        @default("common")
    points      Int           @default(10)
    createdAt   DateTime      @default(now())
    userBadges  UserBadge[]

    @@map("badges")
}

model UserBadge {
    id         String   @id @default(cuid())
    userId     String
    badgeId    String
    unlockedAt DateTime @default(now())
    badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, badgeId])
    @@index([userId])
    @@map("user_badges")
}

enum TaskStatus {
    BACKLOG
    TODAY
    DONE
}

enum TaskPriority {
    LOW
    MEDIUM
    HIGH
    URGENT
}

enum FocusSessionStatus {
    IN_PROGRESS
    PAUSED
    COMPLETED
    INTERRUPTED
}

enum AIInteractionType {
    TASK_SUGGESTION
    TASK_BREAKDOWN
    MOTIVATION
    PRODUCTIVITY_TIP
}

enum BadgeCategory {
    FOCUS
    CONSISTENCY
    PRODUCTIVITY
    SOCIAL
    MILESTONE
}
